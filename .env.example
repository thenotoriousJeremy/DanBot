# Discord bot token
DISCORD_TOKEN=your_bot_token

# Optional alternate token env name
# BOT_TOKEN=your_bot_token

# Optional OpenAI key for workout messages
OPENAI_TOKEN=your_openai_token

# Optional channel/thread id for workout tracking
WORKOUT_CHANNEL_ID=1327019216510910546

# Optional channel id for Wordle stats
WORDLE_CHANNEL_ID=708795613575249941

# Optional custom ffmpeg path
# FFMPEG_PATH=/usr/bin/ffmpeg

# Optional custom cookies file path for yt-dlp
# YTDLP_COOKIE_FILE=./cookies.txt
